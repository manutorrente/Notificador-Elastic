# =============================================================================
# Elasticsearch - Production Connection (elastic_prod)
# =============================================================================
ELASTICSEARCH_PROD_HOST=localhost
ELASTICSEARCH_PROD_PORT=9200
ELASTICSEARCH_PROD_USERNAME=elastic
ELASTICSEARCH_PROD_PASSWORD=your_prod_password_here
ELASTICSEARCH_PROD_VERIFY_CERTS=false
ELASTICSEARCH_PROD_CA_CERTS=

# =============================================================================
# Elasticsearch - Development Connection (elastic_desa)
# =============================================================================
ELASTICSEARCH_DESA_HOST=localhost
ELASTICSEARCH_DESA_PORT=9200
ELASTICSEARCH_DESA_USERNAME=elastic
ELASTICSEARCH_DESA_PASSWORD=your_desa_password_here
ELASTICSEARCH_DESA_VERIFY_CERTS=false
ELASTICSEARCH_DESA_CA_CERTS=

# =============================================================================
# Polling Configuration
# =============================================================================
POLLING_INTERVAL=15

# =============================================================================
# SMTP Email Configuration
# =============================================================================
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password

# =============================================================================
# Discord Bot Configuration (only needed for discordBot method)
# =============================================================================
DISCORD_BOT_TOKEN=your_discord_bot_token_here
